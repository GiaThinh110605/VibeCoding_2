<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-graduation-cap me-2"></i>Thêm ngành học mới</h2>
    <a href="/majors" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Quay lại
    </a>
</div>

{{#if query.success}}
<div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="fas fa-check-circle me-2"></i>{{query.success}}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{{/if}}

{{#if query.error}}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="fas fa-exclamation-circle me-2"></i>{{query.error}}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{{/if}}

<div class="card">
    <div class="card-body">
        <form method="POST" action="/majors/add">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="major_id" class="form-label">Mã ngành *</label>
                    <input type="text" class="form-control" id="major_id" name="major_id" 
                           placeholder="VD: CNTT, KT, NN" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="major_name" class="form-label">Tên ngành *</label>
                    <input type="text" class="form-control" id="major_name" name="major_name" 
                           placeholder="VD: Công nghệ thông tin" required>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label for="description" class="form-label">Mô tả</label>
                    <textarea class="form-control" id="description" name="description" rows="3" 
                              placeholder="Nhập mô tả chi tiết về ngành học..."></textarea>
                </div>
            </div>
            <div class="d-flex justify-content-end gap-2">
                <a href="/majors" class="btn btn-secondary">Hủy</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Lưu ngành học
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Hướng dẫn</h5>
    </div>
    <div class="card-body">
        <ul>
            <li><strong>Mã ngành:</strong> Mã định danh duy nhất cho ngành học (không chứa ký tự đặc biệt)</li>
            <li><strong>Tên ngành:</strong> Tên đầy đủ của ngành học</li>
            <li><strong>Mô tả:</strong> Mô tả chi tiết về ngành học (không bắt buộc)</li>
            <li><strong>Lưu ý:</strong> Mã ngành sẽ được sử dụng để phân loại sách theo lĩnh vực</li>
        </ul>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('form');
    const majorIdInput = document.getElementById('major_id');
    const majorNameInput = document.getElementById('major_name');
    
    form.addEventListener('submit', function(e) {
        const majorId = majorIdInput.value.trim();
        const majorName = majorNameInput.value.trim();
        
        if (!majorId) {
            e.preventDefault();
            alert('Vui lòng nhập mã ngành!');
            return;
        }
        
        if (!majorName) {
            e.preventDefault();
            alert('Vui lòng nhập tên ngành!');
            return;
        }
        
        // Validate major_id format (no special characters, max 10 chars)
        if (!/^[A-Z0-9_]{2,10}$/.test(majorId)) {
            e.preventDefault();
            alert('Mã ngành phải từ 2-10 ký tự, chỉ chứa chữ hoa, số và dấu gạch dưới!');
            return;
        }
    });
    
    // Auto-format major_id
    majorIdInput.addEventListener('input', function() {
        let value = this.value.toUpperCase().replace(/[^A-Z0-9_]/g, '');
        this.value = value;
    });
});
</script>
