<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-hand-holding me-2"></i>Mượn sách</h2>
    <a href="/borrowing" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Quay lại
    </a>
</div>

{{#if query.success}}
<div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="fas fa-check-circle me-2"></i>{{query.success}}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{{/if}}

{{#if query.error}}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="fas fa-exclamation-circle me-2"></i>{{query.error}}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{{/if}}

<div class="card">
    <div class="card-body">
        <form method="POST" action="/borrowing/borrow">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="reader_id" class="form-label">Mã độc giả</label>
                    <input type="text" class="form-control" id="reader_id" name="reader_id" placeholder="VD: SV2024001" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="copy_id" class="form-label">Mã bản sao sách</label>
                    <input type="text" class="form-control" id="copy_id" name="copy_id" placeholder="VD: COPY00101" required>
                </div>
            </div>
            <div class="d-flex justify-content-end gap-2">
                <a href="/borrowing" class="btn btn-secondary">Hủy</a>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-hand-holding me-2"></i>Xác nhận mượn sách
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Hướng dẫn</h5>
    </div>
    <div class="card-body">
        <ol>
            <li>Nhập mã độc giả đã được đăng ký trong hệ thống</li>
            <li>Nhập mã bản sao sách muốn mượn</li>
            <li>Đảm bảo sách có sẵn để mượn (trạng thái "available")</li>
            <li>Thời hạn mượn mặc định là 14 ngày</li>
            <li>Mỗi độc giả chỉ có thể mượn tối đa 5 sách cùng lúc</li>
        </ol>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('form');
    const readerIdInput = document.getElementById('reader_id');
    const copyIdInput = document.getElementById('copy_id');
    
    form.addEventListener('submit', function(e) {
        const readerId = readerIdInput.value.trim();
        const copyId = copyIdInput.value.trim();
        
        if (!readerId) {
            e.preventDefault();
            alert('Vui lòng nhập mã độc giả!');
            return;
        }
        
        if (!copyId) {
            e.preventDefault();
            alert('Vui lòng nhập mã bản sao sách!');
            return;
        }
        
        // Validate copy_id format
        if (!/^[A-Z]+\d+$/.test(copyId)) {
            e.preventDefault();
            alert('Mã bản sao phải có định dạng hợp lệ (ví dụ: TEST00101)');
            return;
        }
    });
    
    // Auto-format inputs
    readerIdInput.addEventListener('input', function() {
        this.value = this.value.toUpperCase();
    });
    
    copyIdInput.addEventListener('input', function() {
        let value = this.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
        this.value = value;
    });
});
</script>
