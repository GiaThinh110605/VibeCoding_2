<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - Hệ thống Quản lý Thư viện</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .sidebar {
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        .sidebar .nav-link {
            color: rgba(255, 255, 255, 0.8);
            padding: 12px 20px;
            margin: 5px 0;
            border-radius: 8px;
            transition: all 0.3s;
        }
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            background: rgba(255, 255, 255, 0.2);
            color: white;
        }
        .main-content {
            background-color: #f8f9fa;
            min-height: 100vh;
        }
        .stat-card {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
            transition: transform 0.3s;
            border-left: 4px solid transparent;
        }
        .stat-card:hover {
            transform: translateY(-5px);
        }
        .stat-card.books {
            border-left-color: #007bff;
        }
        .stat-card.borrowed {
            border-left-color: #28a745;
        }
        .stat-card.overdue {
            border-left-color: #ffc107;
        }
        .stat-card.readers {
            border-left-color: #17a2b8;
        }
        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin-bottom: 15px;
        }
        .user-profile {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            padding: 15px;
            margin-top: auto;
        }
        .quick-action-card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
            transition: all 0.3s;
            cursor: pointer;
        }
        .quick-action-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        }
        .quick-action-icon {
            width: 50px;
            height: 50px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            margin-bottom: 15px;
        }
        .table-status {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }
        .status-borrowed {
            background-color: #d4edda;
            color: #155724;
        }
        .status-returned {
            background-color: #cce5ff;
            color: #004085;
        }
        .status-overdue {
            background-color: #fff3cd;
            color: #856404;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                <div class="position-sticky pt-3">
                    <div class="text-center mb-4">
                        <i class="fas fa-book-open fa-3x mb-2"></i>
                        <h5>VNU Library</h5>
                    </div>
                    
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link active" href="/dashboard">
                                <i class="fas fa-home me-2"></i> Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/readers">
                                <i class="fas fa-id-card me-2"></i> Quản lý thẻ độc giả
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/books">
                                <i class="fas fa-book me-2"></i> Quản lý sách
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/majors">
                                <i class="fas fa-graduation-cap me-2"></i> Quản lý chuyên ngành
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/borrowing">
                                <i class="fas fa-exchange-alt me-2"></i> Mượn - Trả sách
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/reports">
                                <i class="fas fa-chart-bar me-2"></i> Báo cáo thống kê
                            </a>
                        </li>
                        {{#if (eq user.role 'admin')}}
                        <li class="nav-item">
                            <a class="nav-link" href="/staff">
                                <i class="fas fa-users me-2"></i> Quản lý nhân viên
                            </a>
                        </li>
                        {{/if}}
                        <li class="nav-item">
                            <a class="nav-link" href="/settings">
                                <i class="fas fa-cog me-2"></i> Cài đặt
                            </a>
                        </li>
                    </ul>
                    
                    <div class="user-profile">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-user-circle fa-2x me-3"></i>
                            <div>
                                <div class="fw-bold">{{user.full_name}}</div>
                                <small>{{#if (eq user.role 'admin')}}Quản trị viên{{else}}Thủ thư{{/if}}</small>
                            </div>
                        </div>
                        <a href="/logout" class="btn btn-sm btn-outline-light mt-2 w-100">
                            <i class="fas fa-sign-out-alt me-1"></i> Đăng xuất
                        </a>
                    </div>
                </div>
            </nav>

            <!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content">
                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center py-3">
                    <div class="flex-grow-1">
                        <h2 class="mb-0">Bảng điều khiển</h2>
                        <p class="text-muted">Xin chào {{user.full_name}}, chào mừng trở lại!</p>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="input-group" style="max-width: 300px;">
                            <span class="input-group-text"><i class="fas fa-search"></i></span>
                            <input type="text" class="form-control" placeholder="Tìm kiếm tài liệu, độc giả...">
                        </div>
                        <button class="btn btn-light position-relative">
                            <i class="fas fa-bell"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">3</span>
                        </button>
                        <button class="btn btn-light">
                            <i class="fas fa-question-circle"></i> Hỗ trợ ?
                        </button>
                    </div>
                </div>

                <!-- Statistics Cards -->
                <div class="row mb-4">
                    <div class="col-md-3 mb-3">
                        <div class="stat-card books">
                            <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                                <i class="fas fa-book"></i>
                            </div>
                            <h3 class="mb-1">{{bookStats.total_titles}}</h3>
                            <p class="text-muted mb-1">Tổng đầu sách</p>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="stat-card borrowed">
                            <div class="stat-icon bg-success bg-opacity-10 text-success">
                                <i class="fas fa-hand-holding"></i>
                            </div>
                            <h3 class="mb-1">{{borrowingStats.currently_borrowed}}</h3>
                            <p class="text-muted mb-1">Đang mượn</p>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="stat-card overdue">
                            <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                                <i class="fas fa-exclamation-triangle"></i>
                            </div>
                            <h3 class="mb-1">{{borrowingStats.overdue_books}}</h3>
                            <p class="text-muted mb-1">Sách quá hạn</p>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="stat-card readers">
                            <div class="stat-icon bg-info bg-opacity-10 text-info">
                                <i class="fas fa-users"></i>
                            </div>
                            <h3 class="mb-1">{{readerStats.active_readers}}</h3>
                            <p class="text-muted mb-1">Độc giả hoạt động</p>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="row mb-4">
                    <div class="col-md-4 mb-3">
                        <a href="/readers/add" class="text-decoration-none">
                            <div class="quick-action-card">
                                <div class="quick-action-icon bg-primary bg-opacity-10 text-primary">
                                    <i class="fas fa-id-card"></i>
                                </div>
                                <h5>Đăng ký thẻ mới</h5>
                                <p class="text-muted mb-0">Tạo mới thông tin độc giả</p>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-4 mb-3">
                        <a href="/books/add" class="text-decoration-none">
                            <div class="quick-action-card">
                                <div class="quick-action-icon bg-success bg-opacity-10 text-success">
                                    <i class="fas fa-plus-circle"></i>
                                </div>
                                <h5>Thêm sách mới</h5>
                                <p class="text-muted mb-0">Nhập đầu sách hoặc bản sao</p>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-4 mb-3">
                        <a href="/borrowing/return" class="text-decoration-none">
                            <div class="quick-action-card">
                                <div class="quick-action-icon bg-warning bg-opacity-10 text-warning">
                                    <i class="fas fa-undo"></i>
                                </div>
                                <h5>Xử lý trả sách</h5>
                                <p class="text-muted mb-0">Quét mã và kiểm tra sách trả</p>
                            </div>
                        </a>
                    </div>
                </div>

                <!-- Recent Activities -->
                <div class="bg-white rounded shadow-sm">
                    <div class="p-3 border-bottom">
                        <h5 class="mb-0">Hoạt động mượn gần đây</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Mã độc giả</th>
                                    <th>Họ tên</th>
                                    <th>Tên sách</th>
                                    <th>Ngày mượn</th>
                                    <th>Tình trạng</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each recentBorrowings}}
                                <tr>
                                    <td><strong>{{reader_id}}</strong></td>
                                    <td>{{full_name}}</td>
                                    <td>{{title_name}}</td>
                                    <td>{{formatDate borrow_date}}</td>
                                    <td>
                                        {{#if (eq status 'borrowed')}}
                                            <span class="table-status status-borrowed">Đang mượn</span>
                                        {{else if (eq status 'returned')}}
                                            <span class="table-status status-returned">Đã trả</span>
                                        {{else}}
                                            <span class="table-status status-overdue">Quá hạn</span>
                                        {{/if}}
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </td>
                                </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                    <div class="p-3 border-top">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted">Hiển thị 1-{{recentBorrowings.length}} trên {{borrowingStats.total_borrowed}} kết quả</span>
                            <nav>
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item disabled">
                                        <a class="page-link" href="#" tabindex="-1">Previous</a>
                                    </li>
                                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                                    <li class="page-item">
                                        <a class="page-link" href="#">Next</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</body>
</html>
