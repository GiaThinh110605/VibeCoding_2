<div class="d-flex justify-content-between align-items-center py-3">
    <div class="flex-grow-1">
        <h2 class="mb-0">Bảng điều khiển</h2>
        <p class="text-muted">Xin chào {{user.full_name}}, chào mừng trở lại!</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <div class="input-group" style="max-width: 300px;">
            <span class="input-group-text"><i class="fas fa-search"></i></span>
            <input type="text" class="form-control" placeholder="Tìm kiếm tài liệu, độc giả...">
        </div>
        <div class="position-relative">
            <button class="btn btn-light position-relative">
                <i class="fas fa-bell"></i>
                <span class="notification-badge">3</span>
            </button>
        </div>
        <button class="btn btn-light">
            <i class="fas fa-question-circle"></i> Hỗ trợ ?
        </button>
    </div>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="stat-card books">
            <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                <i class="fas fa-book"></i>
            </div>
            <div class="stat-number">{{bookStats.total_titles}}</div>
            <p class="text-muted mb-0">Tổng đầu sách</p>
            <small class="text-success">
                <i class="fas fa-arrow-up"></i> +12% so với tháng trước
            </small>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stat-card borrowed">
            <div class="stat-icon bg-success bg-opacity-10 text-success">
                <i class="fas fa-hand-holding"></i>
            </div>
            <div class="stat-number">{{borrowingStats.currently_borrowed}}</div>
            <p class="text-muted mb-0">Đang mượn</p>
            <small class="text-success">
                <i class="fas fa-arrow-up"></i> +8% so với tuần trước
            </small>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stat-card overdue">
            <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="stat-number">{{borrowingStats.overdue_books}}</div>
            <p class="text-muted mb-0">Sách quá hạn</p>
            <small class="text-danger">
                <i class="fas fa-arrow-up"></i> +2 so với hôm qua
            </small>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stat-card readers">
            <div class="stat-icon bg-info bg-opacity-10 text-info">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-number">{{readerStats.active_readers}}</div>
            <p class="text-muted mb-0">Độc giả hoạt động</p>
            <small class="text-success">
                <i class="fas fa-arrow-up"></i> +15% so với tháng trước
            </small>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row mb-4">
    <div class="col-md-8 mb-3">
        <div class="bg-white rounded shadow-sm p-3">
            <h5 class="mb-3">Xu hướng mượn sách 7 ngày qua</h5>
            <div class="chart-container">
                <canvas id="borrowingTrendChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="bg-white rounded shadow-sm p-3">
            <h5 class="mb-3">Phân loại sách</h5>
            <div class="chart-container">
                <canvas id="bookCategoryChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row mb-4">
    <div class="col-md-4 mb-3">
        <a href="/readers/add" class="text-decoration-none">
            <div class="quick-action-card">
                <div class="quick-action-icon bg-primary bg-opacity-10 text-primary">
                    <i class="fas fa-id-card"></i>
                </div>
                <h5>Đăng ký thẻ mới</h5>
                <p class="text-muted mb-0">Tạo mới thông tin độc giả</p>
                <div class="mt-2">
                    <small class="text-primary">+5 thẻ mới tuần này</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4 mb-3">
        <a href="/books/add" class="text-decoration-none">
            <div class="quick-action-card">
                <div class="quick-action-icon bg-success bg-opacity-10 text-success">
                    <i class="fas fa-plus-circle"></i>
                </div>
                <h5>Thêm sách mới</h5>
                <p class="text-muted mb-0">Nhập đầu sách hoặc bản sao</p>
                <div class="mt-2">
                    <small class="text-success">+12 sách mới tháng này</small>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4 mb-3">
        <a href="/borrowing/return" class="text-decoration-none">
            <div class="quick-action-card">
                <div class="quick-action-icon bg-warning bg-opacity-10 text-warning">
                    <i class="fas fa-undo"></i>
                </div>
                <h5>Xử lý trả sách</h5>
                <p class="text-muted mb-0">Quét mã và kiểm tra sách trả</p>
                <div class="mt-2">
                    <small class="text-warning">{{borrowingStats.currently_borrowed}} đang chờ trả</small>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- Recent Activities -->
<div class="row">
    <div class="col-md-8 mb-3">
        <div class="bg-white rounded shadow-sm">
            <div class="p-3 border-bottom">
                <h5 class="mb-0">Hoạt động mượn gần đây</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã độc giả</th>
                            <th>Họ tên</th>
                            <th>Tên sách</th>
                            <th>Ngày mượn</th>
                            <th>Tình trạng</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each recentBorrowings}}
                        <tr>
                            <td><strong>{{reader_id}}</strong></td>
                            <td>{{full_name}}</td>
                            <td>{{title_name}}</td>
                            <td>{{formatDate borrow_date}}</td>
                            <td>
                                {{#if (eq status 'borrowed')}}
                                    <span class="table-status status-borrowed">Đang mượn</span>
                                {{else if (eq status 'returned')}}
                                    <span class="table-status status-returned">Đã trả</span>
                                {{else}}
                                    <span class="table-status status-overdue">Quá hạn</span>
                                {{/if}}
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            <div class="p-3 border-top">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted">Hiển thị 1-{{recentBorrowings.length}} trên {{borrowingStats.total_borrowed}} kết quả</span>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item disabled">
                                <a class="page-link" href="#" tabindex="-1">Previous</a>
                            </li>
                            <li class="page-item active"><a class="page-link" href="#">1</a></li>
                            <li class="page-item"><a class="page-link" href="#">2</a></li>
                            <li class="page-item"><a class="page-link" href="#">3</a></li>
                            <li class="page-item">
                                <a class="page-link" href="#">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="bg-white rounded shadow-sm">
            <div class="p-3 border-bottom">
                <h5 class="mb-0">Thông báo hệ thống</h5>
            </div>
            <div class="p-3">
                <div class="activity-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-1">Sách quá hạn</h6>
                            <p class="text-muted small mb-0">{{borrowingStats.overdue_books}} sách cần thu hồi</p>
                        </div>
                        <span class="badge bg-warning">Cảnh báo</span>
                    </div>
                </div>
                <div class="activity-item success">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-1">Sách mới</h6>
                            <p class="text-muted small mb-0">12 sách mới được thêm vào tuần này</p>
                        </div>
                        <span class="badge bg-success">Thông tin</span>
                    </div>
                </div>
                <div class="activity-item danger">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-1">Hệ thống</h6>
                            <p class="text-muted small mb-0">Backup dữ liệu thành công</p>
                        </div>
                        <span class="badge bg-danger">Hệ thống</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.stat-card {
    background: white;
    border-radius: 15px;
    padding: 25px;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s;
    border-left: 4px solid transparent;
    position: relative;
    overflow: hidden;
}
.stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
}
.stat-card.books {
    border-left-color: #007bff;
}
.stat-card.borrowed {
    border-left-color: #28a745;
}
.stat-card.overdue {
    border-left-color: #ffc107;
}
.stat-card.readers {
    border-left-color: #17a2b8;
}
.stat-icon {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    margin-bottom: 15px;
}
.stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 5px;
}
.quick-action-card {
    background: white;
    border-radius: 15px;
    padding: 20px;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
    transition: all 0.3s;
    cursor: pointer;
    height: 100%;
}
.quick-action-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
}
.quick-action-icon {
    width: 50px;
    height: 50px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    margin-bottom: 15px;
}
.table-status {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
}
.status-borrowed {
    background-color: #d4edda;
    color: #155724;
}
.status-returned {
    background-color: #cce5ff;
    color: #004085;
}
.status-overdue {
    background-color: #fff3cd;
    color: #856404;
}
.chart-container {
    position: relative;
    height: 300px;
}
.activity-item {
    border-left: 3px solid #e9ecef;
    padding-left: 15px;
    margin-bottom: 20px;
    position: relative;
}
.activity-item::before {
    content: '';
    position: absolute;
    left: -8px;
    top: 5px;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: #007bff;
}
.activity-item.success::before {
    background: #28a745;
}
.activity-item.warning::before {
    background: #ffc107;
}
.activity-item.danger::before {
    background: #dc3545;
}
.notification-badge {
    position: absolute;
    top: -5px;
    right: -5px;
    background: #dc3545;
    color: white;
    border-radius: 50%;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: bold;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// Borrowing trend chart
const borrowingCtx = document.getElementById('borrowingTrendChart').getContext('2d');
new Chart(borrowingCtx, {
    type: 'line',
    data: {
        labels: ['Thứ 2', 'Thứ 3', 'Thứ 4', 'Thứ 5', 'Thứ 6', 'Thứ 7', 'CN'],
        datasets: [{
            label: 'Số sách mượn',
            data: [12, 19, 15, 25, 22, 30, 28],
            borderColor: '#007bff',
            backgroundColor: 'rgba(0, 123, 255, 0.1)',
            tension: 0.4,
            fill: true
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                display: false
            }
        },
        scales: {
            y: {
                beginAtZero: true
            }
        }
    }
});

// Book category chart
const categoryCtx = document.getElementById('bookCategoryChart').getContext('2d');
new Chart(categoryCtx, {
    type: 'doughnut',
    data: {
        labels: ['CNTT', 'Kinh tế', 'Ngôn ngữ', 'Kỹ thuật', 'Khác'],
        datasets: [{
            data: [30, 25, 20, 15, 10],
            backgroundColor: [
                '#007bff',
                '#28a745',
                '#ffc107',
                '#17a2b8',
                '#6c757d'
            ]
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                position: 'bottom'
            }
        }
    }
});

// Auto-refresh dashboard every 30 seconds
setInterval(() => {
    location.reload();
}, 30000);
</script>
