<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-user-plus me-2"></i>Đăng ký thẻ độc giả mới</h2>
    <a href="/readers" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Quay lại
    </a>
</div>

{{#if query.success}}
<div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="fas fa-check-circle me-2"></i>{{query.success}}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{{/if}}

{{#if query.error}}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="fas fa-exclamation-circle me-2"></i>{{query.error}}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{{/if}}

<div class="card">
    <div class="card-body">
        <form method="POST" action="/readers/add">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="full_name" class="form-label">Họ và tên *</label>
                    <input type="text" class="form-control" id="full_name" name="full_name" 
                           placeholder="Nhập họ và tên" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="class" class="form-label">Lớp</label>
                    <input type="text" class="form-control" id="class" name="class" 
                           placeholder="VD: DHKTPM12A">
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label for="birth_date" class="form-label">Ngày sinh *</label>
                    <input type="date" class="form-control" id="birth_date" name="birth_date" required>
                </div>
                <div class="col-md-4 mb-3">
                    <label for="gender" class="form-label">Giới tính *</label>
                    <select class="form-select" id="gender" name="gender" required>
                        <option value="">Chọn giới tính</option>
                        <option value="male">Nam</option>
                        <option value="female">Nữ</option>
                        <option value="other">Khác</option>
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label for="phone" class="form-label">Số điện thoại *</label>
                    <input type="tel" class="form-control" id="phone" name="phone" 
                           placeholder="09xxxxxxxx" required>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="email" class="form-label">Email</label>
                    <input type="email" class="form-control" id="email" name="email" 
                           placeholder="email@example.com">
                </div>
                <div class="col-md-6 mb-3">
                    <label for="address" class="form-label">Địa chỉ</label>
                    <input type="text" class="form-control" id="address" name="address" 
                           placeholder="Nhập địa chỉ">
                </div>
            </div>
            <div class="d-flex justify-content-end gap-2">
                <a href="/readers" class="btn btn-secondary">Hủy</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Đăng ký thẻ
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Hướng dẫn</h5>
    </div>
    <div class="card-body">
        <ul>
            <li><strong>Họ và tên:</strong> Nhập đầy đủ họ và tên của độc giả</li>
            <li><strong>Lớp:</strong> Lớp học (đối với sinh viên)</li>
            <li><strong>Ngày sinh:</strong> Định dạng DD/MM/YYYY</li>
            <li><strong>Số điện thoại:</strong> Số điện thoại liên lạc</li>
            <li><strong>Email:</strong> Email để nhận thông báo (không bắt buộc)</li>
            <li><strong>Địa chỉ:</strong> Địa chỉ hiện tại (không bắt buộc)</li>
        </ul>
    </div>
</div>
