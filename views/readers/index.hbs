                </tbody>
            </table>
        </div>
        <div class="alert alert-info mt-3"><i class="fas fa-info-circle me-2"></i>Đang hiển thị dữ liệu mẫu. Vui lòng thêm độc giả thực tế để thay thế.</div>
        {{/if}}
    </div>
</div>

<style>.stat-card { transition: transform 0.3s; } .stat-card:hover { transform: translateY(-5px); box-shadow: 0 5px 15px rgba(0,0,0,0.1); }</style>
