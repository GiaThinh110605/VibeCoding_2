                    <tr><td><span class="badge bg-primary">SV2024002</span></td><td><strong>Trần Thị B</strong></td><td>Kinh tế-K64</td><td>22/07/2001</td><td><i class="fas fa-venus text-danger"></i> Nữ</td><td>0987654321</td><td>tranthib@email.com</td><td>22/07/2026</td><td><span class="badge bg-success">Hoạt động</span></td><td><a href="/readers/edit/SV2024002" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a><button class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa thẻ độc giả này?')"><i class="fas fa-trash"></i></button></td></tr>
