<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - Hệ thống Thư viện</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    {{> layouts/main}}
    
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2><i class="fas fa-user-edit me-2"></i>Chỉnh sửa thông tin độc giả</h2>
                    <a href="/readers" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Quay lại
                    </a>
                </div>

                <div class="card">
                    <div class="card-body">
                        <form method="POST" action="/readers/edit/{{reader.reader_id}}">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="full_name" class="form-label">Họ và tên</label>
                                    <input type="text" class="form-control" id="full_name" name="full_name" 
                                           value="{{reader.full_name}}" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="class" class="form-label">Lớp</label>
                                    <input type="text" class="form-control" id="class" name="class" 
                                           value="{{reader.class}}">
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label for="birth_date" class="form-label">Ngày sinh</label>
                                    <input type="date" class="form-control" id="birth_date" name="birth_date" 
                                           value="{{reader.birth_date}}" required>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label for="gender" class="form-label">Giới tính</label>
                                    <select class="form-control" id="gender" name="gender" required>
                                        <option value="">Chọn giới tính</option>
                                        <option value="male" {{#if (eq reader.gender 'male')}}selected{{/if}}>Nam</option>
                                        <option value="female" {{#if (eq reader.gender 'female')}}selected{{/if}}>Nữ</option>
                                        <option value="other" {{#if (eq reader.gender 'other')}}selected{{/if}}>Khác</option>
                                    </select>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label for="phone" class="form-label">Số điện thoại</label>
                                    <input type="tel" class="form-control" id="phone" name="phone" 
                                           value="{{reader.phone}}" required>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="email" class="form-label">Email</label>
                                    <input type="email" class="form-control" id="email" name="email" 
                                           value="{{reader.email}}">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="address" class="form-label">Địa chỉ</label>
                                    <input type="text" class="form-control" id="address" name="address" 
                                           value="{{reader.address}}">
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="card_expiry_date" class="form-label">Ngày hết hạn</label>
                                    <input type="date" class="form-control" id="card_expiry_date" name="card_expiry_date" 
                                           value="{{reader.card_expiry_date}}">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="status" class="form-label">Trạng thái</label>
                                    <select class="form-control" id="status" name="status" required>
                                        <option value="active" {{#if (eq reader.status 'active')}}selected{{/if}}>Hoạt động</option>
                                        <option value="locked" {{#if (eq reader.status 'locked')}}selected{{/if}}>Bị khóa</option>
                                        <option value="expired" {{#if (eq reader.status 'expired')}}selected{{/if}}>Hết hạn</option>
                                    </select>
                                </div>
                            </div>
                            <div class="d-flex justify-content-end gap-2">
                                <a href="/readers" class="btn btn-secondary">Hủy</a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save me-2"></i>Cập nhật
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
