<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-book me-2"></i>Thêm sách mới</h2>
    <a href="/books" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Quay lại
    </a>
</div>

{{#if query.success}}
<div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="fas fa-check-circle me-2"></i>{{query.success}}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{{/if}}

{{#if query.error}}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="fas fa-exclamation-circle me-2"></i>{{query.error}}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{{/if}}

<div class="card">
    <div class="card-body">
        <form method="POST" action="/books/add">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="title_id" class="form-label">Mã sách *</label>
                    <input type="text" class="form-control" id="title_id" name="title_id" 
                           placeholder="VD: BOOK001" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="title_name" class="form-label">Tên sách *</label>
                    <input type="text" class="form-control" id="title_name" name="title_name" 
                           placeholder="VD: Giáo trình C++" required>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="author" class="form-label">Tác giả *</label>
                    <input type="text" class="form-control" id="author" name="author" 
                           placeholder="VD: Nguyễn Văn A" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="publisher" class="form-label">Nhà xuất bản *</label>
                    <input type="text" class="form-control" id="publisher" name="publisher" 
                           placeholder="VD: NXB Giáo dục" required>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="major_id" class="form-label">Ngành *</label>
                    <select class="form-select" id="major_id" name="major_id" required>
                        <option value="">-- Chọn ngành --</option>
                        {{#if majors.length}}
                        {{#each majors}}
                        <option value="{{major_id}}">{{major_name}}</option>
                        {{/each}}
                        {{else}}
                        <option value="CNTT">Công nghệ thông tin</option>
                        <option value="KT">Kinh tế</option>
                        <option value="NN">Ngôn ngữ</option>
                        <option value="CK">Cơ khí</option>
                        <option value="XD">Xây dựng</option>
                        {{/if}}
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="total_copies" class="form-label">Số bản sao *</label>
                    <input type="number" class="form-control" id="total_copies" name="total_copies" 
                           placeholder="VD: 5" min="1" required>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label for="description" class="form-label">Mô tả</label>
                    <textarea class="form-control" id="description" name="description" rows="3" 
                              placeholder="Nhập mô tả chi tiết về sách..."></textarea>
                </div>
            </div>
            
            <div class="d-flex justify-content-end gap-2">
                <a href="/books" class="btn btn-secondary">Hủy</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Lưu sách
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Hướng dẫn</h5>
    </div>
    <div class="card-body">
        <ul>
            <li><strong>Mã sách:</strong> Mã định danh duy nhất cho mỗi loại sách</li>
            <li><strong>Tên sách:</strong> Tên đầy đủ của sách</li>
            <li><strong>Tác giả:</strong> Tên tác giả hoặc nhóm tác giả</li>
            <li><strong>Nhà xuất bản:</strong> Tên nhà xuất bản</li>
            <li><strong>Ngành:</strong> Chọn ngành học phù hợp với nội dung sách</li>
            <li><strong>Số bản sao:</strong> Tổng số bản sao của sách này</li>
            <li><strong>Mô tả:</strong> Thông tin mô tả chi tiết về sách (không bắt buộc)</li>
        </ul>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('form');
    const titleIdInput = document.getElementById('title_id');
    
    form.addEventListener('submit', async function(e) {
        const titleId = titleIdInput.value.trim();
        
        if (!titleId) {
            e.preventDefault();
            alert('Vui lòng nhập mã sách!');
            return;
        }
        
        // Validate title_id format (BOOK + 3 digits)
        if (!/^BOOK\d{3}$/.test(titleId)) {
            e.preventDefault();
            alert('Mã sách phải có định dạng BOOKXXX (ví dụ: BOOK001)');
            return;
        }
    });
    
    // Auto-format title_id
    titleIdInput.addEventListener('input', function() {
        let value = this.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
        if (value.startsWith('BOOK')) {
            this.value = value;
        } else if (value.length > 0) {
            this.value = 'BOOK' + value.replace('BOOK', '');
        }
    });
});
</script>
